# Cloudflare Tunnel Token
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# Server Configuration
NODE_ENV=production
PORT=4000

# Security Secrets (CRITICAL - Keep these secret!)
# Example: openssl rand -base64 32
SESSION_SECRET=your-session-secret
ENCRYPTION_KEY=your-encryption-key

# Initial Admin User (for database seeding)
# Must be a @dgsw.hs.kr email
INITIAL_ADMIN_EMAIL=admin@dgsw.hs.kr

# Database
# Turso (production recommended)
# ex) libsql://spot-prod-your-org.turso.io
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# DATABASE_URL도 Turso URL과 동일하게 설정
DATABASE_URL=
# Optional: set true only when you want container startup bootstrap on Turso
PRISMA_BOOTSTRAP_ON_START=false

# Google OAuth (for user login)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google OAuth (for YouTube API - shared department account)
YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_API_KEY=your-youtube-api-key

# Service URLs
GOOGLE_CALLBACK_URL=https://your-domain/auth/google/callback
YOUTUBE_REDIRECT_URI=https://your-domain/api/youtube/callback
FRONTEND_URL=https://your-domain
