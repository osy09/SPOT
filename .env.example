# Database
DATABASE_URL="file:./prisma/dev.db"

# Session
SESSION_SECRET="your-random-session-secret-here"

# Google OAuth (for user login)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret"
GOOGLE_CALLBACK_URL="https://yourdomain.com/auth/google/callback"

# YouTube API (for playlist export)
YOUTUBE_CLIENT_ID="your-youtube-client-id.apps.googleusercontent.com"
YOUTUBE_CLIENT_SECRET="GOCSPX-your-youtube-client-secret"
YOUTUBE_REDIRECT_URI="https://yourdomain.com/api/youtube/callback"

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN="your-cloudflare-tunnel-token"

# Frontend URL
FRONTEND_URL="https://yourdomain.com"

# Server
PORT=4000
